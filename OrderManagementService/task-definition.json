{
  "family": "orderservice-task-develop",
  "networkMode": "awsvpc",
  "executionRoleArn": "arn:aws:iam::493789587013:role/ecsTaskExecutionRole",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "containerDefinitions": [
    {
      "name": "orderservice",
      "image": "chaveenn/orderservice:1.0",
      "cpu": 256,
      "memory": 512,
      "essential": true,
      "portMappings": [
        {
          "containerPort": 4000,
          "hostPort": 4000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "PORT",
          "value": "4000"
        },
        {
          "name": "DELIVERY_SERVICE_URL",
          "value": "http://delivery-service-alb-1864288318.eu-north-1.elb.amazonaws.com/delivery"
        },
        {
          "name": "SERVICE_TO_SERVICE_TOKEN",
          "value": "my_internal_service_token"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/orderservice-develop",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}