{
  "family": "orderservice-task",
  "networkMode": "awsvpc",
  "containerDefinitions": [
    {
      "name": "orderservice",
      "image": "katoshera/orderservice:1.0",
      "cpu": 256,
      "memory": 512,
      "essential": true,
      "portMappings": [
        {
          "containerPort": 4000,
          "hostPort": 4000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "PORT",
          "value": "4000"
        },
        {
          "name": "SHOP_SERVICE_URL",
          "value": "http://gateway-alb-943122502.eu-north-1.elb.amazonaws.com/api/products"
        },
        {
          "name": "AUTH_SERVICE_URL",
          "value": "http://auth-service-alb-123456789.eu-north-1.elb.amazonaws.com/api/auth"
        },
        {
          "name": "DELIVERY_SERVICE_URL",
          "value": "DELIVERY_SERVICE_URL=http://localhost:5003/delivery"
        }

      ],
      "secrets": [
        {
          "name": "MONGO_URI",
          "valueFrom": "arn:aws:ssm:eu-north-1:586988810414:parameter/orderservice/MONGO_URI"
        },
        {
          "name": "JWT_SECRET",
          "valueFrom": "arn:aws:ssm:eu-north-1:586988810414:parameter/orderservice/JWT_SECRET"
        }
      ],

      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/orderservice",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::586988810414:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::586988810414:role/ecsTaskExecutionRole"
}
